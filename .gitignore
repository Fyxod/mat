# summary JSON/Markdown, top sheets, final-validation artifacts, and PNGs in
# each `best/` folder remain trackable.
phase1/outputs/**/checkpoints/
phase1/outputs/**/best/theta.pt
phase1/outputs/**/optimizer_state.pt
*.tmp
*.bak
